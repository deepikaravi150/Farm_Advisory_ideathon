# AWS Core
# Copy this file to .env.local and fill in your real credentials.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID="AKIAVAO4NAXJKIWFQEJP"
AWS_SECRET_ACCESS_KEY="s/ft+jMoofDt6JbB8b9x0wjjcrNWk9tTKB42Wa4i"

# OpenAI (LLM + embeddings + speech)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.2
OPENAI_EMBED_MODEL=text-embedding-3-small
# Speech: TTS (text-to-speech) and STT (speech-to-text, Whisper). Defaults shown.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_STT_MODEL=whisper-1

# Qdrant vector DB (RAG)
# In docker-compose the app reaches Qdrant via the service name; when running
# the ingest script from the host use http://localhost:6333
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=farm_docs

# S3
S3_BUCKET_MEDIA=farm-advisor-media
S3_BUCKET_KB=farm-advisor-kb-docs

# SNS
SNS_REGION=ap-south-1

# Auth
JWT_SECRET=change-this-to-a-long-random-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
