# AWS Core
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# OpenAI (LLM + embeddings)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small

# Qdrant vector DB (RAG)
# In docker-compose the app reaches Qdrant via the service name; when running
# the ingest script from the host use http://localhost:6333
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=farm_docs

# S3
S3_BUCKET_MEDIA=farm-advisor-media
S3_BUCKET_KB=farm-advisor-kb-docs

# SNS
SNS_REGION=ap-south-1

# Auth
JWT_SECRET=change-this-to-a-long-random-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
